# ====================================================================
# GeoSWMM Gateway — environment template
# Copy this file to .env and fill in real values. Never commit .env.
# ====================================================================

# ---- Postgres ------------------------------------------------------
# Used by the postgres container and by the app's DATABASE_URL.
POSTGRES_PASSWORD=change-me-to-a-long-random-string

# DSN the app uses to connect to Postgres (asyncpg driver).
DATABASE_URL=postgresql+asyncpg://gateway:change-me-to-a-long-random-string@postgres:5432/gateway

# Test database (used by pytest). Same server, different db name.
TEST_DATABASE_URL=postgresql+asyncpg://gateway:change-me-to-a-long-random-string@postgres:5432/gateway_test

# ---- Redis ---------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ---- JWT -----------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRES_MIN=15
REFRESH_TOKEN_EXPIRES_DAYS=30

# ---- OpenRouter ----------------------------------------------------
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ---- Qdrant --------------------------------------------------------
QDRANT_URL=https://your-cluster.cloud.qdrant.io
QDRANT_API_KEY=...

# ---- Policy --------------------------------------------------------
# Comma-separated. Models not in this list are rejected at the gateway.
# This allow-list gates BOTH /v1/messages (chat) AND /v1/embeddings —
# add embedding models here too. The gateway resolves prices from
# gateway.billing.PRICES_PER_MTOKEN (chat) and EMBEDDING_PRICES_PER_MTOKEN
# (embeddings); a model in the allow-list but missing from those tables
# logs ``billing.unpriced_*`` and stores ``cost_usd=NULL`` for that row.
ALLOWED_MODELS=anthropic/claude-opus-4.7,anthropic/claude-sonnet-4.6,anthropic/claude-haiku-4.5,openai/text-embedding-3-small,openai/text-embedding-3-large

# Default monthly USD cap applied to new users (overridable per-user in the DB).
# Enforced by the P4 cap check (gateway.limits.enforce_monthly_cap):
# every authenticated /v1/messages call SUMs cost_usd since the start
# of the current calendar month and rejects with 402 when spent >= cap.
# The 402 response detail carries cap_usd + spent_usd so the add-in can
# render an accurate "$X of $Y used" message.
DEFAULT_MONTHLY_USD_CAP=10.00

# Per-row truncation for request_body and response_body in request_log.
# Also drives the request-side size cap (REJECTED at 4 * MAX_BODY_BYTES
# via the RequestSizeLimitMiddleware in gateway.main) so a malicious
# client can't OOM the worker by streaming 100 MB of synthetic content.
MAX_BODY_BYTES=32000

# Per-user QPM allowed by the Redis token bucket (gateway.ratelimit).
# Capacity matches this number and refills at value/60 tokens per
# second, so a user can burst the whole minute's budget at once and
# then refill at the steady-state rate. Atomic via Lua so concurrent
# requests from the same user don't race past capacity. Rejected
# requests get 429 + Retry-After (and detail.retry_after_sec).
# /v1/usage is NOT rate-limited — reading your own spend should never
# be gated.
RATE_LIMIT_PER_MIN=30

# ---- Logging -------------------------------------------------------
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# json | console
LOG_FORMAT=json

# ---- Server --------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=2

# Public hostname Caddy serves (only used in prod; ignored locally).
PUBLIC_HOSTNAME=api.your-domain.com
